# Host port -> container 8080
COMMERCE_SITE_PORT=8080

# Public URL used in links/emails
PUBLIC_BASE_URL=http://127.0.0.1:8080
APP_NAME=Glitcho

# Price shown on landing/pricing pages
PRO_PRICE_CENTS=2900
PRO_CURRENCY=usd

# Download configuration
# Either set direct URL or mount file at /data/Glitcho.zip
DOWNLOAD_URL=
DOWNLOAD_FILE_PATH=/data/Glitcho.zip

# Security / session
SESSION_SECRET=change-me-for-production
MAGIC_LINK_TTL_MINUTES=20
ADMIN_EMAILS=admin@example.com

# Optional SMTP (leave empty for local dev magic-link preview)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@glitcho.local

# Stripe (leave empty for local manual mode)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
ALLOW_MANUAL_CHECKOUT=true

# Licensing signature key
# Startup script generates /data/license-private.pem when missing
LICENSE_PRIVATE_KEY_PEM_FILE=/data/license-private.pem
LICENSE_OFFLINE_GRACE_HOURS=48
LICENSE_VALIDATE_RATE_PER_MINUTE=120
AUTH_REQUEST_RATE_PER_MINUTE=15
